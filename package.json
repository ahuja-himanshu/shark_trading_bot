{
  "name": "shark-telegram-trading-manager",
  "version": "0.1.0",
  "description": "A security-first Telegram management console for Shark Exchange perpetual futures.",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm test",
    "dev": "tsx watch src/main.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "start": "node dist/main.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "shark-exchange",
    "telegram-bot",
    "perpetual-futures",
    "trading"
  ],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "3.1089.0",
    "decimal.js": "10.6.0",
    "pg": "8.22.0",
    "pino": "10.3.1",
    "socket.io-client": "4.8.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/node": "26.1.1",
    "@types/pg": "8.20.0",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.2",
    "prettier": "3.8.2",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.1.10"
  }
}
