NODE_ENV=production
LOG_LEVEL=info
SHARK_API_BASE_URL=https://api.sharkexchange.in
SHARK_PUBLIC_STREAM_URL=https://fawss.sharkexchange.in
SHARK_ACCOUNT_STREAM_URL=https://fawss-uds.sharkexchange.in/auth-stream
AWS_REGION=ap-south-1
AWS_SECRETS_MANAGER_SECRET_ID=replace-at-deployment
TRADING_ENABLED=false
DRAFT_TTL_SECONDS=120
RECONCILIATION_INTERVAL_SECONDS=60
MARKET_QUOTE_MAX_AGE_MS=5000
MARKET_SUBSCRIPTION_LEASE_SECONDS=900
WEBSOCKET_STALE_AFTER_SECONDS=300
WEBSOCKET_MAX_MESSAGE_BYTES=262144
SHARK_LISTEN_KEY_RENEWAL_SECONDS=2700
CONFIRMATION_MATERIAL_CHANGE_BPS=25
