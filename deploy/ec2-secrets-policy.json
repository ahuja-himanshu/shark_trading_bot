{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadOnlyOneRuntimeSecret",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": "REPLACE_WITH_RUNTIME_SECRET_ARN"
    },
    {
      "Sid": "DecryptOnlyRuntimeSecretKey",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "REPLACE_WITH_KMS_KEY_ARN",
      "Condition": {
        "StringEquals": {
          "kms:ViaService": "secretsmanager.ap-south-1.amazonaws.com"
        }
      }
    }
  ]
}
